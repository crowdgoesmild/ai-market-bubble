# Required for live market data from Tiingo.
TIINGO_API_TOKEN=

# Optional free FRED macro-data API key. Without this, macro signals remain inactive.
FRED_API_KEY=

# Optional but recommended for SEC API etiquette. Include a real contact email if possible.
SEC_USER_AGENT=ai-bubble-monitor/0.2 contact@example.com

# Optional. GitHub Actions provides GITHUB_TOKEN automatically; local runs can leave this blank.
GITHUB_TOKEN=

# Optional. Public Hugging Face endpoints usually work without a token.
HF_TOKEN=

# Optional Discord alert webhook.
DISCORD_WEBHOOK_URL=

# Optional public dashboard URL included in Discord notifications.
DASHBOARD_URL=https://<your-github-user>.github.io/ai-bubble-monitor/
